<!-- Script to show today's date -->
<script>
function showDate() {
    const today = new Date();
    document.getElementById("date").innerHTML =
        today.toLocaleDateString("en-US", {
            weekday: "long",
            month: "long",
            day: "numeric",
            year: "numeric"
        });
}
</script>

